# ==========================================
# Kallara Backend - Environment Configuration
# ==========================================

# 1. Server Configuration
PORT=5000
NODE_ENV=development # Set to 'production' in production
CORS_ORIGIN=http://localhost:3000 # In production, set to your Next.js app URL

# 2. Database Connection Options
# Option A: Connection String (Recommended for Production / Cloud DBs e.g., Render, Railway)
DATABASE_URL=postgresql://postgres:admin@localhost:5432/kallara

# Option B: Individual Credentials (Used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=admin
DB_NAME=kallara

# 3. Security & Token Settings
JWT_SECRET=kallara_super_secret_jwt_key_2026_authentication_token # Change to a strong random string in production
JWT_EXPIRES_IN=24h
BCRYPT_SALT_ROUNDS=10

# 4. Rate Limiting Settings
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes (in milliseconds)
RATE_LIMIT_MAX=100 # Maximum requests per window per IP

# 5. Razorpay Configuration (For future integration)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# 6. Email / SMTP Configuration (For future notification dispatch integration)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username_here
SMTP_PASS=your_smtp_password_here
SMTP_FROM_EMAIL=noreply@kallara.com
SMTP_FROM_NAME="Kallara Global Concierge"
